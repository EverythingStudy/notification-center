<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.notification.mapper.NotificationDeadLetterMapper">

    <resultMap id="BaseResultMap" type="com.notification.model.entity.NotificationDeadLetter">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="message_id" property="messageId" jdbcType="VARCHAR"/>
        <result column="original_payload" property="originalPayload" jdbcType="VARCHAR"/>
        <result column="channel" property="channel" jdbcType="VARCHAR"/>
        <result column="error_reason" property="errorReason" jdbcType="VARCHAR"/>
        <result column="retry_count" property="retryCount" jdbcType="INTEGER"/>
        <result column="failed_at" property="failedAt" jdbcType="TIMESTAMP"/>
        <result column="is_resolved" property="isResolved" jdbcType="BOOLEAN"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, message_id, original_payload, channel, error_reason,
        retry_count, failed_at, is_resolved
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO notification_dead_letter (message_id, original_payload, channel,
            error_reason, retry_count, failed_at, is_resolved)
        VALUES (#{messageId}, #{originalPayload}, #{channel},
            #{errorReason}, #{retryCount}, #{failedAt}, #{isResolved})
    </insert>

    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification_dead_letter WHERE id = #{id}
    </select>

    <select id="findByIsResolvedFalseAndFailedAtBefore" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification_dead_letter
        WHERE is_resolved = 0 AND failed_at &lt; #{before}
    </select>

    <select id="findByMessageId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification_dead_letter WHERE message_id = #{messageId}
    </select>

</mapper>
