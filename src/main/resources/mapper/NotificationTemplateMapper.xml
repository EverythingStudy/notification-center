<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.notification.mapper.NotificationTemplateMapper">

    <resultMap id="BaseResultMap" type="com.notification.model.entity.NotificationTemplate">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="template_code" property="templateCode" jdbcType="VARCHAR"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="channels" property="channels" jdbcType="VARCHAR"/>
        <result column="category" property="category" jdbcType="VARCHAR"/>
        <result column="title_template" property="titleTemplate" jdbcType="VARCHAR"/>
        <result column="content_template" property="contentTemplate" jdbcType="VARCHAR"/>
        <result column="wechat_template_id" property="wechatTemplateId" jdbcType="VARCHAR"/>
        <result column="sms_template_name" property="smsTemplateName" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, template_code, name, channels, category, title_template, content_template,
        wechat_template_id, sms_template_name, created_at, updated_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO notification_template (template_code, name, channels, category,
            title_template, content_template, wechat_template_id, sms_template_name,
            created_at, updated_at)
        VALUES (#{templateCode}, #{name}, #{channels}, #{category},
            #{titleTemplate}, #{contentTemplate}, #{wechatTemplateId}, #{smsTemplateName},
            #{createdAt}, #{updatedAt})
    </insert>

    <update id="updateById">
        UPDATE notification_template
        <set>
            <if test="templateCode != null">template_code = #{templateCode},</if>
            <if test="name != null">name = #{name},</if>
            <if test="channels != null">channels = #{channels},</if>
            <if test="category != null">category = #{category},</if>
            <if test="titleTemplate != null">title_template = #{titleTemplate},</if>
            <if test="contentTemplate != null">content_template = #{contentTemplate},</if>
            <if test="wechatTemplateId != null">wechat_template_id = #{wechatTemplateId},</if>
            <if test="smsTemplateName != null">sms_template_name = #{smsTemplateName},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification_template WHERE id = #{id}
    </select>

    <select id="findByTemplateCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification_template WHERE template_code = #{templateCode}
    </select>

    <select id="existsByTemplateCode" resultType="boolean">
        SELECT COUNT(1) FROM notification_template WHERE template_code = #{templateCode}
    </select>

</mapper>
